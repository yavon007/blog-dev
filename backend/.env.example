APP_ENV=development
APP_NAME=blog-backend
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# CORS - 允许的前端域
PUBLIC_ALLOWED_ORIGINS=http://localhost:5173

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://blog:blogpass@localhost:5432/blog?sslmode=disable
DATABASE_MAX_OPEN=50
DATABASE_MAX_IDLE=10
DATABASE_MAX_LIFETIME=30m

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (生产环境请使用 RSA 密钥对，开发环境可用 HMAC secret)
JWT_SECRET=change-me-in-production-use-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# 限流 (requests per second)
RATE_LIMIT_PUBLIC_RPS=20
RATE_LIMIT_ADMIN_RPS=5
