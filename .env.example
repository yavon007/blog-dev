# =============================================================
# docker-compose 环境变量配置
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件不应提交到版本控制
# =============================================================

# ---- 应用 ----
APP_ENV=production
LOG_LEVEL=info

# ---- 端口映射 ----
BACKEND_PORT=8080
FRONTEND_PORT=80

# ---- PostgreSQL ----
POSTGRES_DB=blog
POSTGRES_USER=blog
# 必填：使用强随机密码，例如：openssl rand -hex 32
POSTGRES_PASSWORD=

# ---- Redis ----
# 可选：留空则无密码（生产环境建议设置）
REDIS_PASSWORD=

# ---- JWT ----
# 必填：使用强随机密钥，例如：openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---- CORS ----
# 生产环境填写实际域名，多个域名用逗号分隔
PUBLIC_ALLOWED_ORIGINS=https://yourdomain.com

# ---- 限流 ----
RATE_LIMIT_PUBLIC_RPS=20
RATE_LIMIT_ADMIN_RPS=5
